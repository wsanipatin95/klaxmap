:host {
  display: block;
  width: 100%;
  height: 100dvh;
  min-height: 0;
  overflow: hidden;
  font-family: Arial, Helvetica, sans-serif;
}

.mapa-embed-layout {
  --sidebar-width-expanded: 292px;
  --toolbar-height: 40px;
  --status-height: 32px;

  display: grid;
  grid-template-columns: var(--sidebar-width-expanded) minmax(0, 1fr);
  grid-template-rows: auto minmax(0, 1fr) var(--status-height);
  grid-template-areas:
    'sidebar toolbar'
    'sidebar canvas'
    'status status';
  width: 100%;
  max-width: 100vw;
  height: 100dvh;
  min-height: 0;
  overflow: hidden;
  overscroll-behavior: none;
  background: #d8dee7;
}

.mapa-embed-layout .sidebar {
  grid-area: sidebar;
  min-width: 0;
  min-height: 0;
  overflow: hidden;
  background: #eef2f7;
  border-right: 1px solid #cbd5e1;
}

.mapa-embed-layout .toolbar {
  grid-area: toolbar;
  min-width: 0;
  min-height: var(--toolbar-height);
  background: #eef2f7;
  border-bottom: 1px solid #cbd5e1;
  position: relative;
  z-index: 60;
}

.mapa-embed-layout .canvas {
  grid-area: canvas;
  position: relative;
  overflow: hidden;
  background: #d8dee7;
  min-width: 0;
  min-height: 0;
  isolation: isolate;
}

.mapa-embed-layout .canvas-surface {
  position: absolute;
  inset: 0;
  z-index: 1;
  min-width: 0;
  min-height: 0;
  background: #d8dee7;
  overflow: hidden;
}

.mapa-embed-layout .status {
  grid-area: status;
  min-width: 0;
  background: #111827;
  border-top: 1px solid #1e293b;
  position: relative;
  z-index: 50;
}

.mapa-embed-canvas {
  width: 100%;
  height: 100%;
  min-width: 0;
  min-height: 0;
}

/* Sidebar administrativo */
.mapa-embed-layout .sidebar-shell {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
  overflow: hidden;
  background: #eef2f7;
  color: #334155;
}

.embed-location-strip {
  flex: 0 0 auto;
  min-height: 0;
  overflow: hidden;
  background: #eef2f7;
  border-bottom: 1px solid #d8dee6;
  padding: 0.18rem;
}

.embed-location-title {
  display: flex;
  align-items: center;
  gap: 0.28rem;
  min-height: 20px;
  padding: 0 0.24rem;
  color: #3b5c79;
  font-size: 0.68rem;
  font-weight: 700;
}

.embed-location-title i {
  color: #7b0061;
  font-size: 0.72rem;
}

.embed-location-title strong {
  margin-left: auto;
  color: #059669;
  font-size: 0.58rem;
}

.embed-location-controls {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 28px 28px 28px;
  gap: 2px;
  align-items: end;
  margin-top: 0.12rem;
}

.embed-location-controls label {
  display: grid;
  gap: 0.08rem;
  min-width: 0;
  color: #475569;
  font-size: 0.58rem;
  font-weight: 700;
}

.embed-location-controls input {
  width: 100%;
  height: 26px;
  border: 1px solid #cbd5e1;
  border-radius: 3px;
  background: #ffffff;
  color: #334155;
  padding: 0 0.35rem;
  outline: none;
  font-size: 0.66rem;
  font-weight: 700;
}

.embed-location-controls input:focus {
  border-color: #b02365;
  box-shadow: 0 0 0 2px rgba(123, 0, 97, 0.12);
}

.mapa-embed-layout .sidebar-sections {
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #eef2f7;
}

.mapa-embed-layout .sidebar-pane {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  min-height: 0;
  background: #f8fafc;
}

.mapa-embed-layout .embed-info-pane {
  flex: 0 0 auto;
  max-height: 180px;
  border-top: 1px solid #cbd5e1;
}

.mapa-embed-layout .pane-header {
  width: 100%;
  min-height: 20px;
  border: 0;
  border-bottom: 1px solid #cbd5e1;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
  color: #33506a;
  padding: 0 0.28rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  cursor: default;
}

.mapa-embed-layout .pane-header-left {
  display: inline-flex;
  align-items: center;
  gap: 0.24rem;
  min-width: 0;
}

.mapa-embed-layout .pane-title {
  font-size: 0.68rem;
  font-weight: 700;
  color: #3b5c79;
  letter-spacing: 0.01em;
}

.mapa-embed-layout .pane-toggle-icon {
  width: 12px;
  display: inline-flex;
  justify-content: center;
  font-size: 0.56rem;
  color: #475569;
}

.embed-count {
  min-width: 18px;
  height: 15px;
  border-radius: 999px;
  background: #7b0061;
  color: #ffffff;
  display: inline-grid;
  place-items: center;
  font-size: 0.56rem;
  font-weight: 800;
}

.embed-close-mini {
  width: 16px;
  height: 16px;
  border-radius: 3px;
  display: inline-grid;
  place-items: center;
  color: #475569;
  font-size: 0.76rem;
  cursor: pointer;
}

.embed-close-mini:hover {
  background: #f1f5f9;
  color: #7b0061;
}

.mapa-embed-layout .pane-body {
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  background: #f8fafc;
}

.embed-nearby-list {
  height: 100%;
  min-height: 0;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 0.14rem 0.12rem;
  scrollbar-width: thin;
}

.embed-message {
  display: flex;
  align-items: center;
  gap: 0.28rem;
  min-height: 24px;
  margin: 0.12rem;
  padding: 0.22rem 0.32rem;
  border: 1px solid #d8dee6;
  border-radius: 3px;
  background: #ffffff;
  color: #475569;
  font-size: 0.64rem;
  font-weight: 600;
}

.embed-message.error {
  color: #991b1b;
  border-color: #fecaca;
  background: #fff1f2;
}

.mini-loader {
  width: 0.68rem;
  height: 0.68rem;
  border-radius: 999px;
  border: 2px solid #cbd5e1;
  border-top-color: #7b0061;
  animation: embedSpin 0.72s linear infinite;
}

@keyframes embedSpin {
  to {
    transform: rotate(360deg);
  }
}

.embed-nearby-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 2px;
  align-items: center;
  min-height: 31px;
  margin-bottom: 2px;
  padding: 2px;
  border: 1px solid transparent;
  border-radius: 3px;
  background: #ffffff;
}

.embed-nearby-row:nth-child(even) {
  background: #f7f9fc;
}

.embed-nearby-row:hover {
  border-color: #d8dee6;
  background: #ffffff;
}

.embed-nearby-row.selected {
  border-color: #b02365;
  background: #fdf2f8;
  box-shadow: inset 3px 0 0 #7b0061;
}

.embed-row-main {
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  gap: 0.24rem;
  align-items: center;
  min-width: 0;
  min-height: 26px;
  padding: 0 0.16rem;
  border: 0;
  border-radius: 2px;
  background: transparent;
  color: #334155;
  cursor: pointer;
  text-align: left;
}

.embed-row-main:hover {
  color: #7b0061;
}

.embed-row-icon {
  width: 16px;
  height: 16px;
  border: 1px solid #7b0061;
  border-radius: 999px;
  display: inline-grid;
  place-items: center;
  color: #ffffff;
  font-size: 0.5rem;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.12);
}

.embed-row-text {
  display: grid;
  min-width: 0;
  line-height: 1.02;
}

.embed-row-text strong {
  color: #334155;
  font-size: 0.62rem;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.embed-row-text span {
  color: #64748b;
  font-size: 0.54rem;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.embed-row-text em {
  color: #9a3412;
  font-size: 0.54rem;
  font-style: normal;
  font-weight: 800;
}

.embed-row-actions {
  display: inline-flex;
  gap: 2px;
}

.embed-row-actions .tool-btn {
  width: 22px;
  height: 22px;
}

.embed-info-body,
.embed-tech-body {
  padding: 0.34rem;
  display: grid;
  gap: 0.28rem;
  overflow: auto;
  max-height: 156px;
}

.embed-info-body strong {
  color: #334155;
  font-size: 0.68rem;
  font-weight: 800;
  line-height: 1.1;
}

.embed-info-body > span {
  color: #64748b;
  font-size: 0.58rem;
  font-weight: 600;
}

.embed-info-body p {
  margin: 0;
  color: #475569;
  font-size: 0.58rem;
  line-height: 1.25;
}

.embed-info-body dl {
  display: grid;
  gap: 1px;
  margin: 0;
}

.embed-info-body dl div {
  display: grid;
  grid-template-columns: 70px minmax(0, 1fr);
  gap: 0.35rem;
  min-height: 18px;
  align-items: center;
  border-bottom: 1px solid #e2e8f0;
}

.embed-info-body dt {
  color: #64748b;
  font-size: 0.56rem;
  font-weight: 700;
}

.embed-info-body dd {
  margin: 0;
  color: #334155;
  font-size: 0.56rem;
  font-weight: 800;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.embed-info-actions {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  flex-wrap: wrap;
}

.embed-draft {
  display: grid;
  gap: 0.25rem;
}

.embed-draft label {
  display: grid;
  gap: 0.08rem;
  color: #475569;
  font-size: 0.56rem;
  font-weight: 700;
}

.embed-draft input {
  min-height: 22px;
  border: 1px solid #cbd5e1;
  border-radius: 3px;
  background: #ffffff;
  color: #334155;
  padding: 0 0.35rem;
  font-size: 0.62rem;
}

.error-text {
  margin: 0;
  color: #991b1b;
  font-size: 0.58rem;
  font-weight: 700;
}

/* Toolbar administrativo */
.mapa-embed-layout .ge-toolbar-shell {
  display: flex;
  flex-direction: column;
  gap: 0.12rem;
  min-height: 38px;
  padding: 0.16rem 0.24rem 0.18rem;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
  border-bottom: 1px solid #cbd5e1;
}

.mapa-embed-layout .ge-toolbar-strip {
  display: flex;
  align-items: center;
  gap: 2px;
  width: 100%;
  min-height: 28px;
  padding: 2px;
  border: 1px solid #cbd5e1;
  border-radius: 4px;
  background: linear-gradient(180deg, #ffffff 0%, #eef2f7 100%);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.9),
    0 1px 2px rgba(15, 23, 42, 0.05);
  flex-wrap: nowrap;
  overflow-x: auto;
  overflow-y: visible;
  scrollbar-width: thin;
}

.mapa-embed-layout .tool-btn {
  flex: 0 0 auto;
  width: 28px;
  height: 26px;
  border: 1px solid transparent;
  border-radius: 3px;
  background: transparent;
  color: #475569;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition:
    background 0.15s ease,
    border-color 0.15s ease,
    color 0.15s ease,
    box-shadow 0.15s ease,
    opacity 0.15s ease;
}

.mapa-embed-layout .tool-btn:hover:not(:disabled) {
  background: #f1f5f9;
  border-color: #cbd5e1;
  color: #7b0061;
}

.mapa-embed-layout .tool-btn.active {
  background: linear-gradient(180deg, #f3aad6 0%, #eb79ba 100%);
  border-color: #b02365;
  color: #ffffff;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
}

.mapa-embed-layout .tool-btn:disabled {
  opacity: 0.42;
  cursor: default;
}

.mapa-embed-layout .tool-btn i {
  font-size: 0.82rem;
}

.mapa-embed-layout .tool-btn--wide {
  width: auto;
  min-width: 28px;
  padding: 0 0.52rem;
  gap: 0.34rem;
}

.mapa-embed-layout .tool-btn-label {
  font-size: 0.68rem;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.mapa-embed-layout .tool-btn-dropdown-icon {
  font-size: 0.62rem;
  transition: transform 0.16s ease;
}

.mapa-embed-layout .tool-btn-dropdown-icon.is-open {
  transform: rotate(180deg);
}

.mapa-embed-layout .tool-separator {
  flex: 0 0 auto;
  width: 1px;
  height: 15px;
  background: #cbd5e1;
  margin: 0 2px;
}

.mapa-embed-layout .toolbar-dropdown {
  position: relative;
  flex: 0 0 auto;
}

.mapa-embed-layout .toolbar-dropdown-menu {
  position: fixed;
  z-index: 3000;
  min-width: 12.8rem;
  padding: 0.24rem;
  border: 1px solid #cbd5e1;
  border-radius: 0.5rem;
  background: #ffffff;
  box-shadow: 0 18px 34px rgba(15, 23, 42, 0.16);
}

.mapa-embed-layout .toolbar-dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.55rem;
  width: 100%;
  min-height: 2rem;
  padding: 0.35rem 0.5rem;
  border: 0;
  border-radius: 0.4rem;
  background: transparent;
  color: #334155;
  cursor: pointer;
  text-align: left;
}

.mapa-embed-layout .toolbar-dropdown-item:hover {
  background: #f8fafc;
}

.mapa-embed-layout .toolbar-dropdown-item.active {
  background: #fdf2f8;
  color: #7b0061;
}

.mapa-embed-layout .toolbar-dropdown-item-text {
  font-size: 0.7rem;
  font-weight: 600;
}

.mapa-embed-layout .edit-action {
  display: inline-flex;
  align-items: center;
  gap: 0.26rem;
  min-height: 22px;
  padding: 0 0.5rem;
  border: 1px solid #cbd5e1;
  border-radius: 3px;
  background: #ffffff;
  color: #475569;
  cursor: pointer;
  font-size: 0.66rem;
}

.mapa-embed-layout .edit-action:hover {
  background: #f8fafc;
}

.mapa-embed-layout .edit-action--primary {
  border-color: #b02365;
  background: #7b0061;
  color: #ffffff;
}

.mapa-embed-layout .edit-action--primary:hover:not(:disabled) {
  background: #921f54;
}

.mapa-embed-layout .edit-action:disabled {
  opacity: 0.5;
  cursor: default;
}

.mapa-embed-statusbar {
  height: 100%;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  overflow: hidden;
  padding: 0 0.5rem;
  color: #cbd5e1;
  font-size: 0.68rem;
}

.mapa-embed-statusbar span {
  display: inline-flex;
  align-items: center;
  gap: 0.18rem;
  min-width: 0;
  max-width: 16rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mapa-embed-statusbar strong {
  color: #ffffff;
  font-weight: 800;
}

/* Iconos y etiquetas reutilizando lenguaje del canvas administrativo */
.mapa-embed-origin-icon-host,
.mapa-div-icon,
.mapa-element-label-host,
.mapa-measure-label-host {
  background: transparent;
  border: 0;
}

.mapa-embed-origin-pin {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 2rem;
  height: 2rem;
  border-radius: 999px 999px 999px 0.35rem;
  transform: translate(-50%, -62%) rotate(-45deg);
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%);
  border: 3px solid #ffffff;
  box-shadow:
    0 0 0 4px rgba(37, 99, 235, 0.18),
    0 12px 22px rgba(2, 6, 23, 0.26);
}

.mapa-embed-origin-symbol {
  transform: rotate(45deg);
  font-size: 0.9rem;
}

.mapa-embed-origin-pulse {
  position: absolute;
  inset: 0.32rem;
  border-radius: 999px;
  background: rgba(59, 130, 246, 0.18);
  animation: originPulse 1.35s ease-out infinite;
}

@keyframes originPulse {
  from {
    transform: scale(0.62);
    opacity: 0.8;
  }
  to {
    transform: scale(1.55);
    opacity: 0;
  }
}

.mapa-point-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center;
  transition:
    transform 0.18s ease,
    filter 0.18s ease,
    opacity 0.18s ease;
}

.mapa-div-icon.is-selected .mapa-point-icon-shell {
  animation: mapa-selected-pulse 1.15s ease-in-out infinite;
  filter:
    drop-shadow(0 0 0.5rem rgba(250, 204, 21, 0.82))
    drop-shadow(0 0 1rem rgba(250, 204, 21, 0.42));
}

@keyframes mapa-selected-pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.18);
  }
  100% {
    transform: scale(1);
  }
}

.leaflet-tooltip.mapa-element-tooltip {
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 999px;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.97) 0%, rgba(8, 18, 36, 0.95) 100%);
  color: #f8fafc;
  box-shadow:
    0 10px 22px rgba(2, 6, 23, 0.2),
    0 2px 8px rgba(2, 6, 23, 0.12);
  font-size: 0.58rem;
  font-weight: 800;
  line-height: 1;
  padding: 0.32rem 0.52rem;
  white-space: nowrap;
  max-width: 14rem;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
  text-align: center;
  backdrop-filter: blur(8px);
}

.leaflet-tooltip.mapa-element-tooltip::before {
  border-top-color: rgba(10, 18, 32, 0.96);
}

.mapa-element-label {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 12rem;
  padding: 0.04rem 0.1rem 0.2rem;
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.94);
  color: #0f172a;
  font-size: 0.48rem;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow:
    0 8px 18px rgba(15, 23, 42, 0.1),
    0 2px 5px rgba(15, 23, 42, 0.06);
  backdrop-filter: blur(10px);
  transform: translate(-50%, calc(-100% - 8px));
  text-align: center;
  user-select: none;
  pointer-events: none;
  bottom: 0.2rem;
}

.mapa-element-label.is-selected {
  border-color: rgba(37, 99, 235, 0.24);
  background: rgba(239, 246, 255, 0.96);
  color: #1d4ed8;
}

.mapa-element-label::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -0.22rem;
  width: 0.42rem;
  height: 0.42rem;
  background: rgba(255, 255, 255, 0.94);
  border-right: 1px solid rgba(148, 163, 184, 0.18);
  border-bottom: 1px solid rgba(148, 163, 184, 0.18);
  transform: translateX(-50%) rotate(45deg);
}

.mapa-element-label.is-selected::after {
  background: rgba(239, 246, 255, 0.96);
}

.mapa-measure-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.24rem 0.46rem;
  border-radius: 999px;
  border: 1px solid rgba(123, 0, 97, 0.4);
  background: rgba(8, 18, 36, 0.96);
  color: #fce7f3;
  font-size: 0.64rem;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: 0 8px 20px rgba(2, 6, 23, 0.32);
}

@media (max-width: 860px) {
  .mapa-embed-layout {
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: var(--toolbar-height) minmax(0, 1fr) 42vh var(--status-height);
    grid-template-areas:
      'toolbar'
      'canvas'
      'sidebar'
      'status';
  }

  .mapa-embed-layout .sidebar {
    border-right: 0;
    border-top: 1px solid #cbd5e1;
  }

  .mapa-embed-layout .embed-info-pane {
    max-height: 130px;
  }
}
