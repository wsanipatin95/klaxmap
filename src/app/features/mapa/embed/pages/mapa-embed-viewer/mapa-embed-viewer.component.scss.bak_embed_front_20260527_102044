:host {
  display: block;
  width: 100%;
  height: 100vh;
  min-height: 520px;
  overflow: hidden;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.embed-viewer {
  display: grid;
  grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
  width: 100%;
  height: 100%;
  background: #0f172a;
}

.panel {
  background: #111827;
  color: #e5e7eb;
  border-right: 1px solid rgba(255, 255, 255, 0.12);
  padding: 14px;
  overflow: auto;
}

.panel header {
  display: grid;
  gap: 4px;
  margin-bottom: 14px;
}

.panel header strong {
  font-size: 18px;
}

.panel header small,
.hint {
  color: #9ca3af;
  font-size: 12px;
}

.state {
  padding: 10px;
  border-radius: 10px;
  background: rgba(59, 130, 246, 0.12);
  margin-bottom: 12px;
}

.state.error,
.error-text {
  color: #fecaca;
}

.controls,
.items,
.selected-box,
.tech-actions,
.draft {
  display: grid;
  gap: 10px;
  margin-bottom: 16px;
}

h3,
h4,
p {
  margin: 0;
}

label {
  display: grid;
  gap: 4px;
  color: #d1d5db;
  font-size: 12px;
}

input,
textarea {
  width: 100%;
  border: 1px solid #374151;
  border-radius: 8px;
  background: #0b1220;
  color: #e5e7eb;
  padding: 8px;
  outline: none;
}

textarea {
  resize: vertical;
}

.buttons {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

button {
  border: 0;
  border-radius: 9px;
  padding: 8px 10px;
  background: #2563eb;
  color: #fff;
  cursor: pointer;
}

button:hover:not(:disabled) {
  filter: brightness(1.08);
}

button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

button.ghost {
  background: #374151;
}

.item {
  width: 100%;
  display: grid;
  text-align: left;
  gap: 2px;
  background: #1f2937;
}

.item.selected {
  outline: 2px solid #60a5fa;
}

.item small {
  color: #9ca3af;
}

.selected-box,
.draft {
  border: 1px solid rgba(96, 165, 250, 0.35);
  border-radius: 12px;
  padding: 10px;
  background: rgba(37, 99, 235, 0.1);
}

.map-wrap {
  min-width: 0;
  min-height: 0;
}

.map {
  width: 100%;
  height: 100%;
}

@media (max-width: 820px) {
  .embed-viewer {
    grid-template-columns: 1fr;
    grid-template-rows: 42vh 58vh;
  }

  .panel {
    order: 2;
    border-right: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .map-wrap {
    order: 1;
  }
}
