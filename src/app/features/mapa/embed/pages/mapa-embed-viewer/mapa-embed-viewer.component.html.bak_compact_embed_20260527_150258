<div class="embed-viewer" [class.is-tecnico]="mode() === 'tecnico'">
  <main class="map-wrap">
    <div #mapEl class="map"></div>

    <div class="map-overlay top-left" *ngIf="origin()">
      <div class="origin-card">
        <span class="origin-dot"></span>
        <div>
          <strong>Tu ubicación</strong>
          <small>{{ origin()?.lat | number:'1.6-6' }}, {{ origin()?.lng | number:'1.6-6' }}</small>
        </div>
      </div>

      <div class="route-card" *ngIf="routeTarget()">
        <strong>Ruta a {{ routeTarget()?.nombre }}</strong>
        <small>{{ routeDistanceText() }}</small>
        <button type="button" (click)="clearRoute()">Limpiar ruta</button>
      </div>
    </div>

    <div class="map-overlay top-right">
      <select [ngModel]="basemapKey()" (ngModelChange)="changeBasemap($event)">
        <option *ngFor="let option of basemapOptions" [ngValue]="option.key">
          {{ option.label }}
        </option>
      </select>
    </div>
  </main>

  <aside class="panel">
    <header class="panel-header">
      <div>
        <strong>{{ mode() === 'tecnico' ? 'Mapa técnico' : 'Mapa vendedor' }}</strong>
        <small *ngIf="context()">Empresa {{ context()?.company }} / {{ context()?.tenant }}</small>
      </div>

      <button type="button" class="icon-btn ghost" title="Cancelar" (click)="cancel()">×</button>
    </header>

    <section class="state" *ngIf="loading()">
      <span class="mini-loader"></span>
      Iniciando mapa embebido...
    </section>

    <section class="state error" *ngIf="!loading() && error()">
      {{ error() }}
    </section>

    <section *ngIf="ready()" class="controls">
      <label>
        Radio de búsqueda
        <div class="input-action">
          <input type="number" min="1" [ngModel]="radioM()" (ngModelChange)="radioM.set(+$event || 1)" />
          <span>m</span>
        </div>
      </label>

      <div class="buttons compact">
        <button type="button" class="primary" (click)="refreshNearby()" [disabled]="loadingItems()">
          <span class="pi pi-search"></span>
          Buscar
        </button>
        <button type="button" (click)="centerOrigin()" [disabled]="!origin()">
          <span class="pi pi-crosshairs"></span>
          Centrar
        </button>
        <button type="button" (click)="locateBrowser()">
          <span class="pi pi-map-marker"></span>
          GPS
        </button>
      </div>

      <p class="hint" *ngIf="loadingItems()">Buscando elementos cercanos...</p>
    </section>

    <section *ngIf="ready()" class="items">
      <div class="section-title">
        <h3>Elementos cercanos</h3>
        <span>{{ items().length }}</span>
      </div>

      <div class="empty-list" *ngIf="!loadingItems() && !items().length">
        No hay elementos cercanos para la posición y radio actual.
      </div>

      <article
        class="item-card"
        *ngFor="let item of items()"
        [class.selected]="selected()?.idGeoElemento === item.idGeoElemento"
      >
        <button type="button" class="item-main" (click)="focusItem(item, true)">
          <span class="item-icon-mini">
            <span>{{ (item.tipoNombre || item.tipoCodigo || 'E').slice(0, 1) }}</span>
          </span>

          <span class="item-text">
            <strong>{{ item.nombre }}</strong>
            <small>{{ item.tipoNombre || item.tipoCodigo || 'Elemento' }}</small>
            <em *ngIf="item.distanciaM != null">{{ item.distanciaM | number:'1.0-0' }} m GPS</em>
          </span>
        </button>

        <div class="item-actions">
          <button type="button" title="Trazar ruta" (click)="traceRoute(item)">
            <span class="pi pi-directions"></span>
          </button>
          <button type="button" title="Información" (click)="openInfo(item)">
            <span class="pi pi-info-circle"></span>
          </button>
          <button type="button" title="Enviar al ERP" (click)="selected.set(item); selectForErp()">
            <span class="pi pi-check"></span>
          </button>
        </div>
      </article>
    </section>

    <section *ngIf="selected() && infoOpen()" class="selected-box">
      <div class="section-title">
        <h3>Información</h3>
        <button type="button" class="icon-btn" (click)="closeInfo()">×</button>
      </div>

      <p><strong>{{ selected()?.nombre }}</strong></p>
      <p>{{ selected()?.tipoNombre || selected()?.tipoCodigo }}</p>
      <p *ngIf="selected()?.descripcion">{{ selected()?.descripcion }}</p>

      <dl>
        <div>
          <dt>Distancia</dt>
          <dd>{{ selected()?.distanciaM != null ? (selected()?.distanciaM | number:'1.0-0') + ' m' : 'N/D' }}</dd>
        </div>
        <div>
          <dt>Estado</dt>
          <dd>{{ selected()?.estado || 'N/D' }}</dd>
        </div>
        <div>
          <dt>Código</dt>
          <dd>{{ selected()?.codigo || selected()?.etiqueta || 'N/D' }}</dd>
        </div>
      </dl>

      <div class="buttons compact">
        <button type="button" class="primary" (click)="selectForErp()">
          {{ mode() === 'tecnico' ? 'Usar caja' : 'Enviar selección' }}
        </button>
        <button type="button" (click)="traceRoute(selected()!)">Trazar ruta</button>
      </div>
    </section>

    <section *ngIf="mode() === 'tecnico' && ready()" class="tech-actions">
      <div class="section-title">
        <h3>Trabajo técnico</h3>
      </div>

      <div class="buttons compact">
        <button
          type="button"
          (click)="startCreateBox()"
          [disabled]="!can('puedeCrearCaja') || !actionEnabled('create_box')"
        >
          <span class="pi pi-plus-circle"></span>
          Caja
        </button>

        <button
          type="button"
          (click)="startDrawFiber()"
          [disabled]="!can('puedeCrearFibra') || !actionEnabled('draw_fiber')"
        >
          <span class="pi pi-share-alt"></span>
          Fibra
        </button>
      </div>

      <div class="draft" *ngIf="draftMode() !== 'none'">
        <h4>{{ draftMode() === 'box' ? 'Nueva caja' : 'Nuevo tendido' }}</h4>
        <p class="hint">Haz click en el mapa para marcar puntos.</p>

        <label>
          idRedNodoFk
          <input type="number" [(ngModel)]="createForm.idRedNodoFk" />
        </label>

        <label>
          idGeoTipoElementoFk
          <input type="number" [(ngModel)]="createForm.idGeoTipoElementoFk" />
        </label>

        <label>
          Nombre
          <input type="text" [(ngModel)]="createForm.nombre" />
        </label>

        <label>
          Descripción
          <textarea rows="2" [(ngModel)]="createForm.descripcion"></textarea>
        </label>

        <p class="hint">Puntos marcados: {{ draftPoints().length }}</p>
        <p class="error-text" *ngIf="createError()">{{ createError() }}</p>

        <div class="buttons compact">
          <button type="button" (click)="useOriginAsDraftPoint()" [disabled]="!origin()">Usar origen</button>
          <button type="button" (click)="undoDraftPoint()" [disabled]="!draftPoints().length">Deshacer</button>
          <button type="button" class="primary" (click)="saveDraft()" [disabled]="saving()">
            {{ saving() ? 'Guardando...' : 'Guardar' }}
          </button>
          <button type="button" class="ghost" (click)="clearDraft()">Cancelar</button>
        </div>
      </div>
    </section>
  </aside>
</div>
