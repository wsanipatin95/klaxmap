<div class="embed-admin-state" *ngIf="loading()">
  <div class="spinner"></div>
  <p>Iniciando mapa administrador...</p>
</div>

<div class="embed-admin-state error" *ngIf="!loading() && error()">
  <h2>No se pudo abrir el mapa</h2>
  <p>{{ error() }}</p>
</div>

<app-mapa-home *ngIf="ready()"></app-mapa-home>
