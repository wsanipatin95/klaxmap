:host {
  display: block;
  width: 100%;
  height: 100vh;
  min-height: 520px;
  overflow: hidden;
  --klax-primary: #7b0061;
  --klax-primary-dark: #4c003c;
  --klax-panel: rgba(15, 23, 42, 0.94);
  --klax-panel-strong: rgba(8, 18, 36, 0.97);
  --klax-border: rgba(148, 163, 184, 0.24);
  --klax-soft: rgba(255, 255, 255, 0.08);
  --klax-text: #f8fafc;
  --klax-muted: #cbd5e1;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.embed-viewer {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 20.5rem;
  width: 100%;
  height: 100%;
  background: #0f172a;
}

.map-wrap {
  position: relative;
  min-width: 0;
  min-height: 0;
}

.map {
  width: 100%;
  height: 100%;
}

.panel {
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.97) 0%, rgba(8, 18, 36, 0.96) 100%);
  color: var(--klax-text);
  border-left: 1px solid var(--klax-border);
  box-shadow: -18px 0 42px rgba(2, 6, 23, 0.32);
  padding: 0.78rem;
  overflow: auto;
}

.panel-header,
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.65rem;
}

.panel-header {
  position: sticky;
  top: -0.78rem;
  z-index: 10;
  margin: -0.78rem -0.78rem 0.72rem;
  padding: 0.74rem 0.78rem;
  background:
    linear-gradient(135deg, var(--klax-primary) 0%, #a0007d 55%, var(--klax-primary-dark) 100%);
  box-shadow: 0 10px 28px rgba(123, 0, 97, 0.28);
}

.panel-header strong {
  display: block;
  font-size: 0.95rem;
  font-weight: 900;
  letter-spacing: 0.01em;
}

.panel-header small {
  display: block;
  margin-top: 0.12rem;
  color: rgba(255, 255, 255, 0.78);
  font-size: 0.68rem;
}

.section-title {
  margin-bottom: 0.48rem;
}

.section-title h3 {
  margin: 0;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #f8fafc;
}

.section-title span {
  min-width: 1.6rem;
  height: 1.25rem;
  border-radius: 999px;
  display: inline-grid;
  place-items: center;
  background: rgba(123, 0, 97, 0.2);
  border: 1px solid rgba(243, 170, 214, 0.22);
  color: #fbcfe8;
  font-size: 0.72rem;
  font-weight: 900;
}

.state {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.62rem 0.68rem;
  border-radius: 0.82rem;
  background: rgba(59, 130, 246, 0.11);
  border: 1px solid rgba(96, 165, 250, 0.2);
  margin-bottom: 0.72rem;
  color: #dbeafe;
  font-size: 0.78rem;
}

.state.error,
.error-text {
  color: #fecaca;
  border-color: rgba(248, 113, 113, 0.24);
  background: rgba(127, 29, 29, 0.16);
}

.mini-loader {
  width: 0.85rem;
  height: 0.85rem;
  border-radius: 999px;
  border: 2px solid rgba(191, 219, 254, 0.3);
  border-top-color: #bfdbfe;
  animation: spin 0.75s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.controls,
.items,
.selected-box,
.tech-actions,
.draft {
  display: grid;
  gap: 0.64rem;
  margin-bottom: 0.82rem;
}

label {
  display: grid;
  gap: 0.28rem;
  color: var(--klax-muted);
  font-size: 0.7rem;
  font-weight: 700;
}

input,
textarea,
select {
  width: 100%;
  border: 1px solid rgba(148, 163, 184, 0.25);
  border-radius: 0.68rem;
  background: rgba(2, 6, 23, 0.62);
  color: #f8fafc;
  padding: 0.56rem 0.66rem;
  outline: none;
  font-size: 0.78rem;
}

input:focus,
textarea:focus,
select:focus {
  border-color: rgba(243, 170, 214, 0.55);
  box-shadow: 0 0 0 3px rgba(123, 0, 97, 0.18);
}

textarea {
  resize: vertical;
}

.input-action {
  position: relative;
}

.input-action span {
  position: absolute;
  right: 0.65rem;
  top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: 0.72rem;
  pointer-events: none;
}

.input-action input {
  padding-right: 2rem;
}

.buttons {
  display: flex;
  gap: 0.42rem;
  flex-wrap: wrap;
}

.buttons.compact {
  gap: 0.38rem;
}

button {
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 999px;
  padding: 0.48rem 0.66rem;
  background: rgba(30, 41, 59, 0.92);
  color: #f8fafc;
  cursor: pointer;
  font-size: 0.72rem;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.36rem;
  line-height: 1;
  transition:
    transform 0.14s ease,
    filter 0.14s ease,
    background 0.14s ease,
    border-color 0.14s ease;
}

button:hover:not(:disabled) {
  transform: translateY(-1px);
  filter: brightness(1.08);
  border-color: rgba(243, 170, 214, 0.4);
}

button:disabled {
  opacity: 0.42;
  cursor: not-allowed;
}

button.primary {
  background: linear-gradient(135deg, var(--klax-primary) 0%, #a0007d 100%);
  border-color: rgba(243, 170, 214, 0.28);
}

button.ghost {
  background: rgba(15, 23, 42, 0.46);
}

.icon-btn {
  width: 1.9rem;
  height: 1.9rem;
  padding: 0;
  font-size: 1rem;
}

.hint {
  color: #9ca3af;
  font-size: 0.7rem;
  margin: 0;
}

.empty-list {
  border: 1px dashed rgba(148, 163, 184, 0.25);
  border-radius: 0.9rem;
  padding: 0.9rem;
  color: #94a3b8;
  font-size: 0.75rem;
  text-align: center;
}

.item-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 0.4rem;
  align-items: center;
  padding: 0.42rem;
  border-radius: 0.92rem;
  background: rgba(15, 23, 42, 0.68);
  border: 1px solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 8px 18px rgba(2, 6, 23, 0.16);
}

.item-card.selected {
  border-color: rgba(243, 170, 214, 0.55);
  box-shadow:
    0 0 0 3px rgba(123, 0, 97, 0.14),
    0 12px 24px rgba(2, 6, 23, 0.24);
}

.item-main {
  min-width: 0;
  width: 100%;
  border: 0;
  border-radius: 0.75rem;
  padding: 0;
  background: transparent;
  display: flex;
  justify-content: flex-start;
  text-align: left;
  gap: 0.55rem;
}

.item-main:hover:not(:disabled) {
  transform: none;
  filter: none;
}

.item-icon-mini {
  width: 2.05rem;
  height: 2.05rem;
  border-radius: 999px;
  flex: 0 0 auto;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.95) 0%, rgba(243, 170, 214, 0.82) 45%, rgba(123, 0, 97, 0.9) 100%);
  box-shadow: 0 0 0 4px rgba(123, 0, 97, 0.14);
  color: #fff;
  font-weight: 900;
}

.item-text {
  min-width: 0;
  display: grid;
  gap: 0.12rem;
}

.item-text strong {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 0.76rem;
  color: #f8fafc;
}

.item-text small {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #cbd5e1;
  font-size: 0.66rem;
}

.item-text em {
  color: #fbbf24;
  font-size: 0.68rem;
  font-style: normal;
  font-weight: 900;
}

.item-actions {
  display: flex;
  gap: 0.28rem;
}

.item-actions button {
  width: 1.9rem;
  height: 1.9rem;
  padding: 0;
  border-radius: 0.68rem;
}

.selected-box,
.draft {
  border: 1px solid rgba(243, 170, 214, 0.24);
  border-radius: 1rem;
  padding: 0.72rem;
  background:
    linear-gradient(180deg, rgba(123, 0, 97, 0.15) 0%, rgba(15, 23, 42, 0.76) 100%);
}

.selected-box p,
.draft p,
.selected-box dl {
  margin: 0;
}

.selected-box p {
  font-size: 0.75rem;
  color: #d1d5db;
}

.selected-box p strong {
  color: #fff;
}

.selected-box dl {
  display: grid;
  gap: 0.38rem;
  margin: 0.5rem 0;
}

.selected-box dl div {
  display: flex;
  justify-content: space-between;
  gap: 0.6rem;
  border-top: 1px solid rgba(148, 163, 184, 0.12);
  padding-top: 0.34rem;
}

.selected-box dt {
  color: #94a3b8;
  font-size: 0.68rem;
}

.selected-box dd {
  margin: 0;
  color: #f8fafc;
  font-size: 0.68rem;
  font-weight: 800;
  text-align: right;
}

.map-overlay {
  position: absolute;
  z-index: 900;
  pointer-events: none;
}

.map-overlay > * {
  pointer-events: auto;
}

.map-overlay.top-left {
  left: 0.82rem;
  top: 0.82rem;
  display: grid;
  gap: 0.5rem;
}

.map-overlay.top-right {
  right: 0.82rem;
  top: 0.82rem;
}

.map-overlay select {
  min-width: 10.5rem;
  background: rgba(8, 18, 36, 0.9);
  border-color: rgba(255, 255, 255, 0.18);
  box-shadow: 0 12px 28px rgba(2, 6, 23, 0.26);
}

.origin-card,
.route-card {
  display: flex;
  align-items: center;
  gap: 0.58rem;
  min-width: 13rem;
  padding: 0.62rem 0.74rem;
  border-radius: 1rem;
  border: 1px solid rgba(148, 163, 184, 0.24);
  background: rgba(8, 18, 36, 0.88);
  color: #f8fafc;
  box-shadow: 0 18px 38px rgba(2, 6, 23, 0.34);
  backdrop-filter: blur(10px);
}

.origin-card strong,
.route-card strong {
  display: block;
  font-size: 0.76rem;
}

.origin-card small,
.route-card small {
  display: block;
  color: #cbd5e1;
  font-size: 0.66rem;
}

.origin-dot {
  width: 0.82rem;
  height: 0.82rem;
  border-radius: 999px;
  background: #3b82f6;
  box-shadow:
    0 0 0 4px rgba(59, 130, 246, 0.18),
    0 0 0 8px rgba(59, 130, 246, 0.09);
}

.route-card {
  display: grid;
  align-items: start;
}

.route-card button {
  width: max-content;
  margin-top: 0.28rem;
  padding: 0.38rem 0.62rem;
}

.mapa-embed-origin-icon-host,
.mapa-embed-element-icon-host,
.mapa-embed-route-arrow-host {
  background: transparent;
  border: 0;
}

.mapa-embed-origin-pin {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 999px 999px 999px 0.35rem;
  transform: translate(-50%, -62%) rotate(-45deg);
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%);
  border: 3px solid #fff;
  box-shadow:
    0 0 0 4px rgba(37, 99, 235, 0.18),
    0 18px 30px rgba(2, 6, 23, 0.32);
}

.mapa-embed-origin-symbol {
  transform: rotate(45deg);
  font-size: 1rem;
}

.mapa-embed-origin-pulse {
  position: absolute;
  inset: 0.25rem;
  border-radius: 999px;
  background: rgba(59, 130, 246, 0.18);
  animation: originPulse 1.4s ease-out infinite;
}

@keyframes originPulse {
  from { transform: scale(0.62); opacity: 0.8; }
  to { transform: scale(1.5); opacity: 0; }
}

.mapa-embed-origin-label {
  position: relative;
  transform: translate(-50%, -3.3rem);
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.58rem;
  border-radius: 999px;
  border: 1px solid rgba(59, 130, 246, 0.26);
  background: rgba(239, 246, 255, 0.96);
  color: #1d4ed8;
  font-size: 0.68rem;
  font-weight: 900;
  white-space: nowrap;
  box-shadow: 0 10px 20px rgba(37, 99, 235, 0.16);
}

.mapa-embed-element-icon {
  display: grid;
  place-items: center;
  border-style: solid;
  border-radius: 999px;
  font-weight: 900;
  line-height: 1;
  transition:
    transform 0.18s ease,
    filter 0.18s ease;
}

.mapa-embed-element-icon i {
  font-size: 0.92rem;
}

.mapa-embed-icon-fallback {
  display: none;
}

.mapa-embed-element-icon-host.is-selected .mapa-embed-element-icon {
  transform: scale(1.18);
  filter:
    drop-shadow(0 0 0.48rem rgba(250, 204, 21, 0.82))
    drop-shadow(0 0 1rem rgba(250, 204, 21, 0.42));
}

.mapa-embed-route-arrow {
  display: grid;
  place-items: center;
  width: 1.9rem;
  height: 1.9rem;
  border-radius: 999px;
  background: rgba(123, 0, 97, 0.95);
  color: #fff;
  border: 2px solid #fff;
  box-shadow: 0 12px 24px rgba(2, 6, 23, 0.28);
  font-size: 1rem;
}

.mapa-embed-route-label {
  border-color: rgba(123, 0, 97, 0.36);
  color: #fce7f3;
}

.leaflet-tooltip.mapa-embed-origin-tooltip {
  border-color: rgba(59, 130, 246, 0.22);
}

@media (max-width: 920px) {
  .embed-viewer {
    grid-template-columns: 1fr;
    grid-template-rows: minmax(320px, 48vh) minmax(0, 52vh);
  }

  .panel {
    border-left: 0;
    border-top: 1px solid var(--klax-border);
  }
}

@media (max-width: 560px) {
  .panel {
    padding: 0.62rem;
  }

  .panel-header {
    margin: -0.62rem -0.62rem 0.62rem;
  }

  .item-card {
    grid-template-columns: 1fr;
  }

  .item-actions {
    justify-content: flex-end;
  }

  .map-overlay.top-left {
    left: 0.6rem;
    top: 0.6rem;
  }

  .map-overlay.top-right {
    right: 0.6rem;
    top: 0.6rem;
  }

  .origin-card,
  .route-card {
    min-width: 0;
    max-width: calc(100vw - 1.2rem);
  }
}
